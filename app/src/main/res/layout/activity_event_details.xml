<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Event Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/colorPrimary"
            android:padding="24dp">

            <TextView
                android:id="@+id/eventTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event Title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/eventDateTimeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date and Time"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:alpha="0.9"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/eventLocationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:alpha="0.9"
                android:drawableStart="@drawable/ic_location"
                android:drawablePadding="8dp" />

        </LinearLayout>

        <!-- Event Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/eventDescriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event description will appear here"
                android:textSize="16sp"
                android:textColor="@color/textColorSecondary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Event Info Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textSize="12sp"
                            android:textColor="@color/textColorSecondary"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/eventCategoryText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Conference"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/textColorPrimary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Price"
                            android:textSize="12sp"
                            android:textColor="@color/textColorSecondary"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/eventPriceText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Free"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorAccent" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendees"
                        android:textSize="12sp"
                        android:textColor="@color/textColorSecondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/eventAttendeesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/100 attendees"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textColorPrimary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/eventOrganizerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Organized by: John Doe"
                        android:textSize="14sp"
                        android:textColor="@color/textColorSecondary" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/bookEventButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Book Event"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/colorAccent" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>